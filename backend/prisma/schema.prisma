// Prisma schema for Access & Tone Rewriter
// UC1: RewriteContentForTargetAudience

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String     @id @default(uuid())
  userId    String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  documents Document[]
}

model Document {
  id              String           @id @default(uuid())
  sessionId       String
  sourceText      String
  createdAt       DateTime         @default(now())
  session         Session          @relation(fields: [sessionId], references: [id])
  rewriteRequests RewriteRequest[]
}

model AudienceProfile {
  id              String           @id @default(uuid())
  name            String           @unique
  linguisticRules Json
  rewriteRequests RewriteRequest[]
}

model RewriteRequest {
  id                   String          @id @default(uuid())
  documentId           String
  audienceProfileId    String
  targetGradeLevel     Int
  rewrittenText        String?
  calculatedGradeLevel Float?
  ambiguityFlag        Boolean         @default(false)
  latencyMs            Int?
  status               String
  createdAt            DateTime        @default(now())
  document             Document        @relation(fields: [documentId], references: [id])
  audienceProfile      AudienceProfile @relation(fields: [audienceProfileId], references: [id])
}
