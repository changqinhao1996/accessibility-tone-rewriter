// Prisma schema for Access & Tone Rewriter
// UC1: RewriteContentForTargetAudience
// UC2: GenerateImageAltText
// UC3: AuditDocumentForAccessibility

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String     @id @default(uuid())
  userId    String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  documents Document[]
}

model Document {
  id              String           @id @default(uuid())
  sessionId       String
  sourceText      String
  createdAt       DateTime         @default(now())
  session         Session          @relation(fields: [sessionId], references: [id])
  rewriteRequests RewriteRequest[]
  images          DocumentImage[]
  auditReports    AuditReport[]
}

model AudienceProfile {
  id              String           @id @default(uuid())
  name            String           @unique
  linguisticRules Json
  rewriteRequests RewriteRequest[]
}

model RewriteRequest {
  id                   String          @id @default(uuid())
  documentId           String
  audienceProfileId    String
  targetGradeLevel     Int
  rewrittenText        String?
  calculatedGradeLevel Float?
  ambiguityFlag        Boolean         @default(false)
  latencyMs            Int?
  status               String
  createdAt            DateTime        @default(now())
  document             Document        @relation(fields: [documentId], references: [id])
  audienceProfile      AudienceProfile @relation(fields: [audienceProfileId], references: [id])
}

// ── UC2: GenerateImageAltText ────────────────────────────────

model DocumentImage {
  id             String         @id @default(uuid())
  documentId     String
  filename       String
  complexityFlag Boolean        @default(false)
  hasAltText     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  document       Document       @relation(fields: [documentId], references: [id])
  altTexts       ImageAltText[]
}

model ImageAltText {
  id            String        @id @default(uuid())
  imageId       String
  altText       String?
  wcagCompliant Boolean       @default(false)
  approved      Boolean       @default(false)
  status        String
  createdAt     DateTime      @default(now())
  image         DocumentImage @relation(fields: [imageId], references: [id])
}

// ── UC3: AuditDocumentForAccessibility ──────────────────────

model Guideline {
  id          String   @id @default(uuid())
  ruleId      String   @unique
  description String
  version     String
  createdAt   DateTime @default(now())
}

model AuditReport {
  id                String           @id @default(uuid())
  documentId        String
  guidelinesVersion String
  status            String
  createdAt         DateTime         @default(now())
  document          Document         @relation(fields: [documentId], references: [id])
  violations        AuditViolation[]
}

model AuditViolation {
  id            String      @id @default(uuid())
  auditReportId String
  ruleId        String
  severity      String
  description   String
  createdAt     DateTime    @default(now())
  auditReport   AuditReport @relation(fields: [auditReportId], references: [id])
}
